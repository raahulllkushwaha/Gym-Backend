# Copy this file to .env and fill in real values. Never commit the real .env file.

# Database
DB_USERNAME=postgres
DB_PASSWORD=change-me

# JWT - generate a long random string (min 256 bits) for production
JWT_SECRET=change-this-to-a-long-random-secret-key-min-256-bits-for-hs256

# Mail (Gmail example - use an App Password, not your real password)
MAIL_USERNAME=your-gym-email@gmail.com
MAIL_APP_PASSWORD=your-16-char-app-password

# Twilio SMS
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Gym branding
GYM_NAME=Iron Forge Gym
FRONTEND_URL=http://localhost:5173

# Bootstrap manager - the ONLY way to get the first login into the system.
# Set these once, start the app, log in, then you may leave them (they're ignored
# once any MANAGER account already exists) or blank them out again.
BOOTSTRAP_MANAGER_USERNAME=admin
BOOTSTRAP_MANAGER_PASSWORD=change-me-immediately
BOOTSTRAP_MANAGER_EMAIL=owner@yourgym.com
BOOTSTRAP_MANAGER_PHONE=9999999999
